      <inertia ixx="105288.72E-06" ixy="5.13E-06" ixz="-916.71E-06"
               iyy="106543.51E-06" iyz="1476.64E-06" izz="5575.56E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="knee_L_Link.STL"/>
      </geometry>
