<?xml version="1.0"?>
<robot name="bipedal_robot">

  <!-- Materials -->
  <material name="grey">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.423 0.039 1.0"/>
  </material>

<!-- ros_control plugin -->
  <gazebo>
    <plugin filename="libtron2_hw_sim.so" name="gazebo_ros_control">
      <robotNamespace>/</robotNamespace>
      <robotParam>robot_description</robotParam>
      <robotSimType>tron2_gazebo/Tron2HWSim</robotSimType>
    </plugin>
  </gazebo>

  <!-- Ground truth pose plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="p3d_base_controller">
      <alwaysOn>true</alwaysOn>
      <updateRate>1000.0</updateRate>
      <bodyName>base_Link</bodyName>
      <topicName>ground_truth/state</topicName>
      <gaussianNoise>0</gaussianNoise>
      <frameName>world</frameName>
      <xyzOffsets>0 0 0</xyzOffsets>
      <rpyOffsets>0 0 0</rpyOffsets>
    </plugin>
  </gazebo>
  <!-- Links -->
  <!-- IMU Link -->
  <joint name="limx_imu_joint" type="fixed">
    <origin rpy="0. 0. 0." xyz="0. 0. 0."/>
    <parent link="base_Link"/>
    <child link="limx_imu"/>
  </joint>

  <link name="limx_imu">
    <inertial>
      <mass value="0.01"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.004"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>

  <gazebo reference="limx_imu_joint">
    <disableFixedJointLumping>true</disableFixedJointLumping>
  </gazebo>

  <link name="base_Link">
    <inertial>
      <origin xyz="-2.05E-03 -0.10E-03 113.04E-03" rpy="0 0 0"/>
      <mass value="11.07"/>
      <inertia ixx="104457.03E-06" ixy="33.54E-06" ixz="7218.53E-06"
               iyy="120930.21E-06" iyz="84.19E-06" izz="88931.63E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base_Link.STL"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="proximal_pitch_L_Link">
    <inertial>
      <origin xyz="-5.22E-03 69.76E-03 -6.08E-03" rpy="0 0 0"/>
      <mass value="2.07"/>
      <inertia ixx="4154.53E-06" ixy="-14.00E-06" ixz="18.41E-06"
               iyy="2922.29E-06" iyz="51.96E-06" izz="3333.39E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="proximal_pitch_L_Link.STL"/>
