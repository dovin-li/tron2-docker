      <geometry>
        <mesh filename="proximal_yaw_L_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="knee_L_Link">
    <inertial>
      <origin xyz="-2.17E-03 -24.32E-03 -137.39E-03" rpy="0 0 0"/>
