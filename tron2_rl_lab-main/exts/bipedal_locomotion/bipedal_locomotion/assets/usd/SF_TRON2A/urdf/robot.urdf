    </collision>
  </link>
  <joint name="proximal_roll_R_Joint" type="revolute">
    <origin xyz="-0.032 -0.0758 -0.00663" rpy="-0.0 0.0 -0.0"/>
    <parent link="proximal_pitch_R_Link"/>
    <child link="proximal_roll_R_Link"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit lower="-3.19395248" upper="0.2617993877991494" effort="150.0" velocity="18.3"/>
  </joint>
  <link name="proximal_yaw_R_Link">
    <inertial>
      <origin xyz="-0.00276 -0.00164 -0.11148" rpy="-0.0 0.0 -0.0"/>
      <mass value="1.56"/>
      <inertia ixx="0.01503966" ixy="3.86e-06" ixz="0.00026664" iyy="0.01434141" iyz="-6.594e-05" izz="0.00375785"/>
