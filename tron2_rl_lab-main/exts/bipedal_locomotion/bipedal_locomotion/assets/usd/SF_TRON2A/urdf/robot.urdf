  <!-- Camera -->
  <link name="d435_Link">
    <visual>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0.0 -0.0 0"/>
      <geometry>
        <box size="0.01 0.01 0.001"/>
      </geometry>
    </visual>
  </link>
  <joint name="d435_joint" type="fixed">
    <origin rpy="0.0 1.063778179 0.0" xyz="0.12213 0.01759 0.00599"/>
    <parent link="limx_imu"/>
    <child link="d435_Link"/>
  </joint>
  <joint name="d435_optical_joint" type="fixed">
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
    <parent link="d435_Link"/>
    <child link="d435_optical_frame"/>
  </joint>
  <link name="d435_optical_frame"/>
  <gazebo reference="d435_Link">
    <sensor type="depth" name="d435_camera_sensor">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>60</update_rate>
      <visualize>false</visualize>
      <camera>
        <horizontal_fov>1.5177</horizontal_fov>
        <image>
          <format>B8G8R8</format>
          <width>64</width>
          <height>48</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>1.8</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>d435</namespace>
        </ros>
        <camera_name>d435_camera</camera_name>
        <frame_name>d435_optical_frame</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>1.8</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Gazebo link physics -->
  <gazebo reference="base_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="proximal_pitch_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="proximal_roll_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="proximal_yaw_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="knee_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="ankle_pitch_L_Link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <material>Gazebo/DarkGrey</material>
    <self_collide>1</self_collide>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
  </gazebo>
  <gazebo reference="proximal_pitch_R_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
