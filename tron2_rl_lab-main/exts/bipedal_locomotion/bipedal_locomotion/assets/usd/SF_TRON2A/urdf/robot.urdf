  </link>
  <joint name="proximal_pitch_L_Joint" type="revolute">
    <origin xyz="-0.00044 0.09178 0.05474" rpy="0.0 0.0 0.0"/>
    <parent link="base_Link"/>
    <child link="proximal_pitch_L_Link"/>
    <axis xyz="0.0 0.9961947268929313 -0.0871554135479712"/>
    <limit lower="-3.141592653589793" upper="2.600540585471551" effort="150.0" velocity="18.3"/>
  </joint>
  <link name="proximal_roll_L_Link">
