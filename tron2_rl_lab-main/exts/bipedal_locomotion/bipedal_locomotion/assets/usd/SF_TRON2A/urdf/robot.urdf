    </collision>
  </link>
  <joint name="ankle_pitch_L_Joint" type="revolute">
    <origin xyz="-0.004 -0.06775 -0.35" rpy="0.0 0.0 0.0"/>
    <parent link="knee_L_Link"/>
    <child link="ankle_pitch_L_Link"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.6231562043547265" upper="1.6231562043547265" effort="60.0" velocity="22.52"/>
  </joint>

  <!-- proximal_pitch_R_Link -->
  <link name="proximal_pitch_R_Link">
    <inertial>
      <origin xyz="-0.00522 -0.06976 -0.00608" rpy="-0.0 0.0 -0.0"/>
