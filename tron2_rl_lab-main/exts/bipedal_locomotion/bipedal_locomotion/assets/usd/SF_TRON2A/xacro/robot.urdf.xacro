        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_yaw_R_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="knee_R_Link">
    <inertial>
      <origin xyz="0.00217 -0.02964 -0.12834" rpy="0 0 0" />
      <mass value="4.25" />
      <inertia ixx="0.09615017" ixy="3.746e-05" ixz="0.00092779"
        iyy="0.09699426" iyz="-0.00286736" izz="0.00528618" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
