  </gazebo>

  <!-- Conditional ROS version -->
  <xacro:if value="${ros_version == 1}">
    <xacro:ros1_gazebo_all />
  </xacro:if>
  <xacro:if value="${ros_version == 2}">
    <xacro:ros2_gazebo_all />
  </xacro:if>

</robot>
