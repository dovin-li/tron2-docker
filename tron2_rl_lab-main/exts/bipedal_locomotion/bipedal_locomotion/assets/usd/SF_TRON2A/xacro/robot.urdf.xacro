        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_yaw_L_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="knee_L_Link">
    <inertial>
      <origin xyz="2.17E-03 29.64E-03 -128.34E-03" rpy="0 0 0" />
      <mass value="4.25" />
      <inertia ixx="96150.17E-06" ixy="-37.46E-06" ixz="927.79E-06"
        iyy="96994.26E-06" iyz="2867.36E-06" izz="5286.18E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/knee_L_Link.STL" />
      </geometry>
      <material name="grey" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/knee_L_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="ankle_pitch_L_Link">
    <inertial>
      <origin xyz="15.25E-03 -35.42E-03 -46.68E-03" rpy="0 0 0" />
      <mass value="1.02" />
      <inertia ixx="1443.30E-06" ixy="35.45E-06" ixz="145.15E-06"
        iyy="3461.81E-06" iyz="-68.35E-06" izz="3941.99E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/ankle_pitch_L_Link.STL" />
