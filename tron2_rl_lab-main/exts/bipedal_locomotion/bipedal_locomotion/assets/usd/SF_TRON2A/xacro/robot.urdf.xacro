        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_roll_L_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="proximal_yaw_L_Link">
    <inertial>
      <origin xyz="2.76E-03 -1.64E-03 -111.48E-03" rpy="0 0 0" />
      <mass value="1.56" />
      <inertia ixx="15039.66E-06" ixy="-3.86E-06" ixz="-266.64E-06"
        iyy="14341.41E-06" iyz="-65.94E-06" izz="3757.85E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_yaw_L_Link.STL" />
