    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_pitch_L_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="proximal_roll_L_Link">
    <inertial>
      <origin xyz="31.24E-03 0.35E-03 -84.14E-03" rpy="0 0 0" />
      <mass value="1.74" />
      <inertia ixx="4769.33E-06" ixy="-11.72E-06" ixz="32.71E-06"
        iyy="5455.84E-06" iyz="-29.46E-06" izz="3053.16E-06" />
