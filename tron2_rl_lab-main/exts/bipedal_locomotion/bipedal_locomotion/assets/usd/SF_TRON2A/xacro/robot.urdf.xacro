      </geometry>
    </collision>
  </link>

  <link name="proximal_roll_R_Link">
    <inertial>
      <origin xyz="0.03124 -0.00035 -0.08414" rpy="0 0 0" />
      <mass value="1.74" />
      <inertia ixx="0.00476933" ixy="1.172e-05" ixz="3.271e-05"
        iyy="0.00545584" iyz="2.946e-05" izz="0.00305316" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_roll_R_Link.STL" />
      </geometry>
      <material name="grey" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_roll_R_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="proximal_yaw_R_Link">
    <inertial>
      <origin xyz="0.00276 0.00164 -0.11148" rpy="0 0 0" />
      <mass value="1.56" />
      <inertia ixx="0.01503966" ixy="3.86e-06" ixz="-0.00026664"
        iyy="0.01434141" iyz="6.594e-05" izz="0.00375785" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/proximal_yaw_R_Link.STL" />
