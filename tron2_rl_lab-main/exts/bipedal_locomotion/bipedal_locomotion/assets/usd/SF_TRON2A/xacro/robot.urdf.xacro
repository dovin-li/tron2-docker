    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/ankle_pitch_L_Link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="proximal_pitch_R_Link">
    <inertial>
      <origin xyz="-0.00522 -0.06976 -0.00608" rpy="0 0 0" />
      <mass value="2.07" />
      <inertia ixx="0.00415453" ixy="1.4e-05" ixz="1.841e-05"
        iyy="0.00292229" iyz="-5.196e-05" izz="0.00333339" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
