  <link name="ankle_pitch_R_Link">
    <inertial>
      <origin xyz="0.01525 0.03542 -0.04668" rpy="0 0 0" />
      <mass value="1.02" />
      <inertia ixx="0.0014433" ixy="-3.545e-05" ixz="0.00014515"
        iyy="0.00346181" iyz="6.835e-05" izz="0.00394199" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/ankle_pitch_R_Link.STL" />
      </geometry>
      <material name="grey" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/SF_TRON2A/meshes/ankle_pitch_R_Link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- D435 Camera Links -->
  <link name="d435_Link">
    <visual>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0.0 -0.0 0" />
      <geometry>
        <box size="0.01 0.01 0.001" />
      </geometry>
      <material name="camera_red">
        <color rgba="1.0 0.0 0.0 1.0" />
      </material>
    </visual>
  </link>

  <joint name="d435_joint" type="fixed">
    <origin rpy="0 1.063778179 0" xyz="0.12213 0.01759 0.00599" />
    <parent link="limx_imu" />
    <child link="d435_Link" />
  </joint>

  <joint name="d435_optical_joint" type="fixed">
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0" />
    <parent link="d435_Link" />
    <child link="d435_optical_frame" />
  </joint>
  <link name="d435_optical_frame" />

  <!-- Joints -->
  <joint name="proximal_pitch_L_Joint" type="revolute">
    <origin xyz="-0.00044 0.09178 0.05474" rpy="0 0 0" />
    <parent link="base_Link" />
    <child link="proximal_pitch_L_Link" />
    <axis xyz="0 0.99619 -0.087155" />
    <limit lower="-3.141592653589793" upper="2.600540585471551" effort="150" velocity="18.3" />
  </joint>

  <joint name="proximal_roll_L_Joint" type="revolute">
    <origin xyz="-0.032 0.0758 -0.00663" rpy="0 0 0" />
    <parent link="proximal_pitch_L_Link" />
    <child link="proximal_roll_L_Link" />
    <axis xyz="1 0 0" />
    <limit lower="-0.2617993877991494" upper="3.19395248" effort="150" velocity="18.3" />
  </joint>

  <joint name="proximal_yaw_L_Joint" type="revolute">
    <origin xyz="0.032 0.0 -0.1374" rpy="0 0 0" />
    <parent link="proximal_roll_L_Link" />
    <child link="proximal_yaw_L_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-0.5235987755982988" upper="4.625122517784973" effort="60" velocity="22.52" />
  </joint>

  <joint name="knee_L_Joint" type="revolute">
    <origin xyz="-0.004 -0.032 -0.2126" rpy="0 0 0" />
    <parent link="proximal_yaw_L_Link" />
    <child link="knee_L_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.2617993877991494" upper="2.6179938779914944" effort="150" velocity="18.3" />
  </joint>

  <joint name="ankle_pitch_L_Joint" type="revolute">
    <origin xyz="0.004 0.06775 -0.35" rpy="0 0 0" />
    <parent link="knee_L_Link" />
    <child link="ankle_pitch_L_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-1.6231562043547263" upper="1.6231562043547263" effort="60" velocity="22.52" />
  </joint>

  <joint name="proximal_pitch_R_Joint" type="revolute">
    <origin xyz="-0.00044 -0.09178 0.05474" rpy="0 0 0" />
    <parent link="base_Link" />
    <child link="proximal_pitch_R_Link" />
    <axis xyz="0 0.99619 0.087155" />
    <limit lower="-3.141592653589793" upper="2.600540585471551" effort="150" velocity="18.3" />
  </joint>

  <joint name="proximal_roll_R_Joint" type="revolute">
    <origin xyz="-0.032 -0.0758 -0.00663" rpy="0 0 0" />
    <parent link="proximal_pitch_R_Link" />
    <child link="proximal_roll_R_Link" />
    <axis xyz="1 0 0" />
    <limit lower="-3.19395248" upper="0.2617993877991494" effort="150" velocity="18.3" />
  </joint>

  <joint name="proximal_yaw_R_Joint" type="revolute">
    <origin xyz="0.032 -0.0 -0.1374" rpy="0 0 0" />
    <parent link="proximal_roll_R_Link" />
    <child link="proximal_yaw_R_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-4.625122517784973" upper="0.5235987755982988" effort="60" velocity="22.52" />
  </joint>

  <joint name="knee_R_Joint" type="revolute">
    <origin xyz="-0.004 0.032 -0.2126" rpy="0 0 0" />
    <parent link="proximal_yaw_R_Link" />
    <child link="knee_R_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.2617993877991494" upper="2.6179938779914944" effort="150" velocity="18.3" />
  </joint>

  <joint name="ankle_pitch_R_Joint" type="revolute">
    <origin xyz="0.004 -0.06775 -0.35" rpy="0 0 0" />
    <parent link="knee_R_Link" />
    <child link="ankle_pitch_R_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-1.6231562043547263" upper="1.6231562043547263" effort="60" velocity="22.52" />
  </joint>

  <!-- Gazebo Material / Friction (shared) -->
  <gazebo reference="proximal_yaw_R_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="proximal_roll_R_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="proximal_yaw_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="proximal_roll_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="ankle_pitch_L_Link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <self_collide>1</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0" />
    <kd value="100.0" />
  </gazebo>

  <gazebo reference="proximal_pitch_L_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="proximal_pitch_R_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="knee_R_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>0</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0" />
    <kd value="100.0" />
  </gazebo>

  <gazebo reference="ankle_pitch_R_Link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <self_collide>1</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0" />
    <kd value="100.0" />
