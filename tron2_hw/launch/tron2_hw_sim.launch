<launch>
    <arg name="robot_type" default="SF_TRON2A"/>
    <arg name="spawn_z" default="0.8"/>
    <arg name="air_hold" default="true"/>
    <arg name="air_hold_duration" default="2.0"/>
    <arg name="hw_startup_delay" default="1.0"/>

    <env name="ROBOT_TYPE" value="$(arg robot_type)"/>

    <include file="$(find tron2_gazebo)/launch/empty_world.launch">
        <arg name="robot_type" value="$(arg robot_type)"/>
        <arg name="spawn_z" value="$(arg spawn_z)"/>
    </include>

    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
        <remap from="joint_states" to="/tron2_hw/joint_states"/>
    </node>

    <include file="$(find tron2_hw)/launch/tron2_hw.launch">
        <arg name="robot_type" value="$(arg robot_type)"/>
        <arg name="robot_ip" value="127.0.0.1"/>
        <arg name="use_gazebo" value="true"/>
        <arg name="load_robot_description" value="false"/>
        <arg name="startup_delay" value="$(arg hw_startup_delay)"/>
    </include>

    <node if="$(arg air_hold)" name="hold_base_in_air" pkg="tron2_gazebo" type="hold_base_in_air.py" output="screen">
        <param name="hold_z" value="$(arg spawn_z)"/>
        <param name="hold_duration" value="$(arg air_hold_duration)"/>
        <param name="model_name" value="tron2_robot"/>
    </node>

    <!-- Xbox joystick via ROS joy_node (like TRON1) -->
    <node name="joy_node" pkg="joy" type="joy_node" output="screen">
        <param name="dev" value="/dev/input/js0"/>
    </node>
    <node name="joy_to_cmdvel" pkg="tron2_gazebo" type="joy_to_cmdvel.py" output="screen"/>

    <!-- Web panel on port 8080 -->
    <node name="web_walk" pkg="tron2_gazebo" type="web_walk.py" output="screen"/>
</launch>
