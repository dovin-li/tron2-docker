  <gazebo reference="camera_mount_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="radar_Link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/White</material>
  </gazebo>

  <!-- Conditional ROS version -->
  <xacro:if value="${ros_version == 1}">
    <xacro:ros1_gazebo_all />
  </xacro:if>
  <xacro:if value="${ros_version == 2}">
    <xacro:ros2_gazebo_all />
  </xacro:if>

</robot>
