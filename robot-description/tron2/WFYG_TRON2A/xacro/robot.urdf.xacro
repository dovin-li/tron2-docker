<?xml version="1.0"?>
<robot name="bipedal_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="ros_version" default="$(optenv ROS_VERSION 2)" />
  <xacro:arg name="use_primitive_collision" default="false" />
  <xacro:property name="ros_version" value="$(arg ros_version)" />
  <xacro:property name="use_primitive" value="$(arg use_primitive_collision)" />

  <xacro:include filename="macros.xacro" />

  <!-- Materials -->
  <material name="grey">
    <color rgba="1 1 1 1" />
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0" />
  </material>
  <material name="orange">
    <color rgba="1.0 0.423 0.039 1.0" />
  </material>

  <!-- IMU Link -->
  <joint name="base_imu_Joint" type="fixed">
    <origin rpy="0. 0. 0." xyz="0. 0. 0." />
    <parent link="base_Link" />
    <child link="base_imu" />
  </joint>

  <link name="base_imu">
    <inertial>
      <mass value="0.01" />
      <origin rpy="0 0 0" xyz="0 0 0" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <box size="0.015 0.015 0.004" />
      </geometry>
      <material name="orange" />
    </visual>
  </link>

  <gazebo reference="base_imu_Joint">
    <disableFixedJointLumping>true</disableFixedJointLumping>
  </gazebo>

  <!-- Links -->
  <link name="base_Link">
    <inertial>
      <origin xyz="3.85E-03 -0.11E-03 112.54E-03" rpy="0 0 0" />
      <mass value="12.57" />
      <inertia ixx="114738.68E-06" ixy="-17.26E-06" ixz="7175.02E-06"
        iyy="135812.53E-06" iyz="81.23E-06" izz="105408.73E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_description/tron2/WFYG_TRON2A/meshes/base_Link.STL" />
      </geometry>
      <material name="grey" />
    </visual>
    <xacro:unless value="${use_primitive}">
      <xacro:collision_mesh mesh_filename="package://robot_description/tron2/WFYG_TRON2A/meshes/base_Link.STL" />
    </xacro:unless>
    <xacro:if value="${use_primitive}">
      <xacro:collision_box
        prim_origin_xyz="0.007348134464503642 0.0032471465881624044 0.10977665292815185"
        prim_origin_rpy="1.5469195434180267 -0.10680015192437434 3.039190661120036"
        prim_size="0.2597991458857211 0.23762547316400467 0.1436914098299209" />
