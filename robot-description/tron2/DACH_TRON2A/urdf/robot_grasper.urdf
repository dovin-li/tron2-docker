    </visual>
  </link>
  <joint name="grasper_L_drive_Joint" type="revolute">
    <origin xyz="0 0.0275 -0.0689" rpy="0 0 0"/>
    <parent link="grasper_base_L_Link"/>
    <child link="grasper_L_crank_left_Link"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.09522" upper="0.77302" effort="2" velocity="10"/>
  </joint>
  <link name="grasper_L_jaw_left_Link">
