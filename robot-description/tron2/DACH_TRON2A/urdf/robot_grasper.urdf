  <!-- ============ grasper L: single-DOF linkage gripper ============
       mechanism: motor->slider(nut)->crank->parallelogram; 1 master + 8 linear followers
       master  : grasper_L_drive_Joint (crank angle, rad), range [-0.09522, 0.77302], 0 = mesh pose
       opening : d(theta) = 0.0500028*(sin(theta-16.271deg)+0.280184) m  (per-finger tip travel)
         closed  theta=-0.09522   d=-4.5mm  (pads touch)
         zero    theta=0         d= 0
         half    theta=+0.33890  d=+16.76mm
         open    theta=0.77302   d=+37.5mm
       grasper_L_jaw_left/right_Joint are READ-ONLY followers reporting ~= opening (linear approx, max err 0.44mm).
       NOTE SAPIEN/MuJoCo ignore <mimic>: RoboTwin drives followers via embodiment config (see docs/dach_grasper_linkage_design.md);
       MuJoCo uses xml/robot_grasper.xml equality constraints instead. -->
  <link name="grasper_base_L_Link">
    <inertial>
      <origin xyz="-5.4461854e-05 0.00010217849 -0.040269646" rpy="0 0 0"/>
      <mass value="0.04219468"/>
      <inertia ixx="4.0267217e-05" ixy="-1.0182089e-07" ixz="1.6771285e-07" iyy="4.0247132e-05" iyz="-1.8502772e-07" izz="3.0206823e-05"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/tron2/DACH_TRON2A/meshes/grasper_L_base_Link.STL"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/tron2/DACH_TRON2A/meshes/grasper_L_base_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="grasper_base_L_Joint" type="revolute">
    <origin xyz="-0.0317 0 -0.0812" rpy="0 0 0"/>
    <parent link="wrist_roll_L_Link"/>
    <child link="grasper_base_L_Link"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="1.8326" effort="20" velocity="10"/>
  </joint>
  <link name="grasper_L_crank_left_Link">
    <inertial>
      <origin xyz="4.7600073e-06 -0.0055481701 -0.019012995" rpy="0 0 0"/>
      <mass value="0.0028716751"/>
      <inertia ixx="8.4974068e-07" ixy="-8.1619392e-11" ixz="-2.8305318e-10" iyy="1.0893102e-06" iyz="-2.2248284e-07" izz="3.9176962e-07"/>
    </inertial>
    <visual>
